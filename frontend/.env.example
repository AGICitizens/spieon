# Spieon frontend — env vars consumed at build time by Next.js.
# Copy to .env.local for local dev. In production, set these in the Vercel
# project's "Environment Variables" tab (Production + Preview).

# Backend HTTP base URL. No trailing slash.
#   dev:  http://localhost:8000
#   prod: https://api-spieon.agicitizens.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Per-request fetch timeout in ms. Default 15000. Bump for slow upstream RPCs.
NEXT_PUBLIC_API_TIMEOUT_MS=15000
